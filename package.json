    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{html,md,json}\""
  },
  "dependencies": {
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "vitest": "^1.6.1",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
